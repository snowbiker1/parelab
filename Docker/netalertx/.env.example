# Example environment variables for NetAlertX Docker Compose
# Copy this file to .env and fill in the values.

# Network mode for the container
# Options: host (default), bridge, etc.
NETALERTX_NETWORK_MODE=

# User and group IDs for the container runtime
# Default: 20211 (non-root user)
NETALERTX_UID=
NETALERTX_GID=

# Application configuration
LISTEN_ADDR=
PORT=
GRAPHQL_PORT=

# Debug mode (0=restart dead services, 1=keep dead services running)
# NETALERTX_DEBUG=0

# Alternative UID/GID overrides (uncomment if needed)
# PUID=
# PGID=
