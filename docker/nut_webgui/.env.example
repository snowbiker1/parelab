# NUT Web GUI Environment Variables
# Host port to expose the web UI (container listens on 9000 by default)
NUT_WEBGUI_HOST_PORT=

# NUT/UPSD connection settings
NUT_WEBGUI_UPSD_ADDR=
NUT_WEBGUI_UPSD_PORT=
NUT_WEBGUI_UPSD_USER=
NUT_WEBGUI_UPSD_PASS=

# Internal port the web UI listens on inside the container
NUT_WEBGUI_PORT=
